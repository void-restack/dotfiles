root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{sh,zsh}]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.lua]
indent_style = space
indent_size = 2

[*.toml]
indent_style = space
indent_size = 2

[*.conf]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
