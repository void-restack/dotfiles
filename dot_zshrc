typeset -g tn_fg="#c0caf5"
typeset -g tn_blue="#7aa2f7"
typeset -g tn_green="#9ece6a"
typeset -g tn_red="#f7768e"
typeset -g tn_yellow="#e0af68"
typeset -g tn_purple="#bb9af7"
typeset -g tn_gray="#565f89"

precmd() {
  if git rev-parse --is-inside-work-tree &>/dev/null; then
    local branch=$(git branch --show-current 2>/dev/null || git rev-parse --short HEAD)
    local git_info="%F{$tn_gray}$branch%f"

    local upstream=$(git rev-parse --abbrev-ref '@{upstream}' 2>/dev/null)
    if [[ -n $upstream && $upstream != '@{upstream}' ]]; then
      local ahead=$(git rev-list --count '@{upstream}..HEAD' 2>/dev/null)
      local behind=$(git rev-list --count 'HEAD..@{upstream}' 2>/dev/null)
      [[ $ahead -gt 0 ]] && git_info+=" %F{$tn_yellow}↑${ahead}%f"
      [[ $behind -gt 0 ]] && git_info+=" %F{$tn_blue}↓${behind}%f"
    fi

    local staged=$(git diff --cached --name-only 2>/dev/null | wc -l | tr -d ' ')
    local changed=$(git diff --name-only 2>/dev/null | wc -l | tr -d ' ')
    local untracked=$(git ls-files --others --exclude-standard 2>/dev/null | wc -l | tr -d ' ')
    [[ $staged -gt 0 ]] && git_info+=" %F{$tn_green}+${staged}%f"
    [[ $changed -gt 0 ]] && git_info+=" %F{$tn_yellow}!${changed}%f"
    [[ $untracked -gt 0 ]] && git_info+=" %F{$tn_red}?${untracked}%f"

    RPROMPT="${git_info}%(?.. %F{$tn_red}exit %?%f)"
  else
    RPROMPT="%(?..%F{$tn_red}exit %?%f)"
  fi
}

PROMPT="%F{$tn_blue}%c%f %(?.%F{$tn_gray}.%F{$tn_red})❯%f "

