killport() {
  local force=""
  local -a ports
  for arg in "$@"; do
    [[ "$arg" == (-f|--force|-9) ]] && { force="-9"; continue; }
    ports+=("$arg")
  done

  if (( ${#ports[@]} == 0 )); then
    echo "Usage: killport [-f|-9] <port> [port...]" >&2
    return 1
  fi

  local -a pids
  for port in "${ports[@]}"; do
    if ! [[ "$port" =~ '^[0-9]+$' ]] || (( port < 1 || port > 65535 )); then
      print -u2 "skipping invalid port: $port"
      continue
    fi
    local -a port_pids
    port_pids=( "${(@f)$(lsof -nP -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null)}" )
    if (( ${#port_pids[@]} == 0 )); then
      print "no process listening on $port"
    else
      print "killing ${port_pids[*]} on port $port"
      pids+=( "${port_pids[@]}" )
    fi
  done

  (( ${#pids[@]} > 0 )) && kill $force "${pids[@]}" 2>/dev/null
}
alias kp='killport'

listport() {
  local -a ports=("$@")
  if (( ${#ports[@]} == 0 )); then
    echo "Usage: listport <port> [port...]" >&2
    return 1
  fi

  for port in "${ports[@]}"; do
    if ! [[ "$port" =~ '^[0-9]+$' ]] || (( port < 1 || port > 65535 )); then
      print -u2 "skipping invalid port: $port"
      continue
    fi
    local out
    out=$(lsof -nP -iTCP:"$port" -sTCP:LISTEN 2>/dev/null)
    [[ -z "$out" ]] && { print "nothing listening on $port"; continue; }
    print -r -- "--- port $port ---"
    print -r -- "$out"
  done
}
alias lp='listport'

